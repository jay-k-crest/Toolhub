---
interface Props {
  placement: "result-below" | "mid-content" | "sidebar-sticky" | "in-feed";
  className?: string;
}

const { placement, className = "" } = Astro.props;

// Alternating fallback sponsor choices
const isDevHub = placement === "result-below" || placement === "sidebar-sticky";
const adUrl = isDevHub ? "https://devcurrent.vercel.app/" : "https://interviewgenie-omega.vercel.app";
---

<div class={`ad-container w-full flex flex-col items-center justify-center my-6 ${className}`}>
  {/* Live AdSense element block. Priority 1. */}
  <ins class="adsbygoogle block w-full opacity-100 transition-opacity duration-300"
       style="display:block"
       data-ad-client="ca-pub-placeholder"
       data-ad-slot={placement}
       data-ad-format="auto"
       data-full-width-responsive="true"></ins>

  {/* Fallback Custom-designed Banners for DevHub AI and InterviewGenie. Priority 2. */}
  <div class="fallback-promo w-full mt-3 relative z-10 select-none">
    
    {/* 1. SKYCSCRAPER SIZE (vertical, e.g. 300x600 px) - for sticky sidebar placement */}
    {placement === "sidebar-sticky" && (
      <div class="w-[300px] min-h-[500px] border border-indigo-500/25 bg-gradient-to-b from-[#111222] via-[#090b16] to-[#04050a] rounded-2xl shadow-xl overflow-hidden p-6 flex flex-col justify-between text-left relative mx-auto">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-indigo-500/10 via-transparent to-transparent pointer-events-none" />
        
        <div>
          <div class="flex items-center justify-between mb-8">
            <span class="inline-flex items-center rounded-full bg-indigo-500/10 border border-indigo-500/20 px-2.5 py-0.5 text-[10px] font-bold text-indigo-400 uppercase tracking-wide">
              Featured Dev Tool
            </span>
            <span class="text-[9px] text-muted-foreground uppercase font-bold tracking-widest">Sponsor</span>
          </div>

          <div class="mb-6 flex items-center gap-3">
            <div class="h-10 w-10 rounded-lg bg-indigo-500/20 flex items-center justify-center text-indigo-400 border border-indigo-500/30">
              <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>
            </div>
            <div>
              <h4 class="text-lg font-heading font-black text-white tracking-tight leading-none">DevHub AI</h4>
              <span class="text-[10px] text-muted-foreground">devcurrent.vercel.app</span>
            </div>
          </div>

          <h3 class="text-xl font-heading font-extrabold text-white leading-snug mb-4">
            Test Sandbox APIs Direct in Your Browser
          </h3>

          <p class="text-xs text-muted-foreground leading-relaxed mb-6">
            Real-time developer news feed aggregator combined with an interactive sandbox API playground. Test endpoints, review headers, and generate integration snippets instantly.
          </p>

          <ul class="space-y-2.5 text-[11px] text-indigo-200/80 mb-8 font-medium">
            <li class="flex items-center gap-2">
              <span class="text-indigo-400">✦</span> 100+ Free Mock Sandbox APIs
            </li>
            <li class="flex items-center gap-2">
              <span class="text-indigo-400">✦</span> Real-Time Dev News Aggregation
            </li>
            <li class="flex items-center gap-2">
              <span class="text-indigo-400">✦</span> Zero Configuration Required
            </li>
          </ul>
        </div>

        <a href={adUrl} target="_blank" rel="noopener noreferrer" class="w-full py-3 px-4 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-xs tracking-wider uppercase rounded-xl text-center transition-all shadow-md shadow-indigo-600/20 hover:shadow-indigo-600/30">
          Try Playground API
        </a>
      </div>
    )}

    {/* 2. RECTANGLE BOX SIZE (standard rectangle, e.g. 336x280 or 300x250) - for mid-content placement */}
    {placement === "mid-content" && (
      <div class="max-w-md w-full border border-emerald-500/20 bg-gradient-to-br from-[#0c1812] via-[#050b07] to-background rounded-2xl p-6 shadow-lg overflow-hidden relative mx-auto text-left">
        <div class="absolute top-0 right-0 h-32 w-32 bg-emerald-500/5 rounded-full blur-2xl pointer-events-none" />
        
        <div class="flex items-center justify-between mb-4">
          <span class="inline-flex items-center rounded-full bg-emerald-500/10 border border-emerald-500/20 px-2 py-0.5 text-[9px] font-bold text-emerald-400 uppercase tracking-wide">
            AI Interview prep
          </span>
          <span class="text-[9px] text-muted-foreground uppercase font-bold tracking-widest">Sponsor</span>
        </div>

        <div class="flex gap-4 items-start mb-4">
          <div class="h-10 w-10 shrink-0 rounded-lg bg-emerald-500/20 flex items-center justify-center text-emerald-400 border border-emerald-500/30">
            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275Z"></path></svg>
          </div>
          <div>
            <h4 class="text-base font-heading font-black text-white tracking-tight leading-none">InterviewGenie</h4>
            <p class="text-xs text-muted-foreground mt-1">AI-powered mock interview practice round coach.</p>
          </div>
        </div>

        <p class="text-xs text-muted-foreground leading-relaxed mb-6">
          Ace your technical interviews. Experience realistic AI coding challenges, system design deep dives, and behavioral scenarios with detailed grading and custom feedback report cards.
        </p>

        <div class="flex gap-3 justify-end items-center">
          <span class="text-[10px] text-muted-foreground italic font-mono">interviewgenie-omega.vercel.app</span>
          <a href={adUrl} target="_blank" rel="noopener noreferrer" class="py-2.5 px-4 bg-emerald-600 hover:bg-emerald-700 text-white font-bold text-xs uppercase tracking-wide rounded-lg transition-all">
            Practice Free Mock
          </a>
        </div>
      </div>
    )}

    {/* 3. HORIZONTAL BANNER (e.g. 728x90 px) - for result-below placement */}
    {placement === "result-below" && (
      <div class="w-full border border-indigo-500/20 bg-gradient-to-r from-[#111222] via-[#090b16] to-[#04050a] rounded-xl p-4 sm:p-5 shadow-sm overflow-hidden relative text-left">
        <div class="absolute inset-y-0 right-0 w-1/3 bg-gradient-to-l from-indigo-500/5 to-transparent pointer-events-none" />
        
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 relative z-10">
          <div class="flex gap-4 items-center">
            <div class="h-10 w-10 rounded-lg bg-indigo-500/20 flex items-center justify-center text-indigo-400 shrink-0 border border-indigo-500/30">
              <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>
            </div>
            <div class="space-y-0.5">
              <div class="flex items-center gap-2">
                <span class="text-[9px] font-bold text-indigo-400 bg-indigo-500/10 border border-indigo-500/20 px-1.5 py-0.2 rounded-md uppercase">DevHub AI</span>
                <span class="text-[9px] text-muted-foreground uppercase tracking-widest font-bold">Partner Sponsor</span>
              </div>
              <h4 class="text-sm sm:text-base font-heading font-extrabold text-white leading-tight">
                Developer News Feed & API Playground Hub
              </h4>
              <p class="text-xs text-muted-foreground max-w-xl leading-relaxed hidden sm:block">
                Discover real-time programming news and interactively test mock API sandboxes live in your browser.
              </p>
            </div>
          </div>
          
          <a href={adUrl} target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto py-2.5 px-4 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-xs uppercase tracking-wide rounded-lg text-center transition-all shrink-0">
            Open Sandbox Playground
          </a>
        </div>
      </div>
    )}

    {/* 4. IN-FEED STRIP (slim horizontal, e.g. 728x70 px) - for category listing feeds */}
    {placement === "in-feed" && (
      <div class="w-full border border-emerald-500/20 bg-gradient-to-r from-[#0c1812] via-[#050b07] to-background rounded-lg p-3 sm:p-4 shadow-sm overflow-hidden relative text-left">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 relative z-10">
          <div class="flex gap-3 items-center">
            <div class="h-8 w-8 rounded-md bg-emerald-500/20 flex items-center justify-center text-emerald-400 shrink-0 border border-emerald-500/25">
              <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275Z"></path></svg>
            </div>
            <div class="space-y-0.5">
              <h4 class="text-xs sm:text-sm font-heading font-extrabold text-white leading-tight">
                Prepare for Tech Interviews with InterviewGenie
              </h4>
              <p class="text-[11px] text-muted-foreground leading-none hidden sm:block">
                Simulate AI-driven code challenges and soft-skills interviews with detailed report cards.
              </p>
            </div>
          </div>
          
          <a href={adUrl} target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto py-2 px-3 bg-emerald-600 hover:bg-emerald-700 text-white font-bold text-xs uppercase tracking-wide rounded-md text-center transition-all shrink-0">
            Start Free Mock Round
          </a>
        </div>
      </div>
    )}
    
  </div>
</div>

{/* Client-side script to monitor Google AdSense loading and toggle visibility */}
<script is:inline>
  function checkAdSenseLoad() {
    document.querySelectorAll('.ad-container').forEach(container => {
      const ins = container.querySelector('ins.adsbygoogle');
      const fallback = container.querySelector('.fallback-promo');
      if (ins && fallback) {
        // If AdSense has dynamically generated an iframe or has filled status
        const isFilled = ins.querySelector('iframe') || ins.getAttribute('data-ad-status') === 'filled';
        if (isFilled) {
          fallback.style.display = 'none';
        } else {
          fallback.style.display = 'block';
        }
      }
    });
  }

  // Periodic checks to cover async loads
  window.addEventListener('load', () => {
    checkAdSenseLoad();
    // Run checks at intervals for AdSense network responses
    const intervals = [1000, 3000, 5000];
    intervals.forEach(t => setTimeout(checkAdSenseLoad, t));
  });
</script>
