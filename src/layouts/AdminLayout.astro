---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { Landmark, Tool, ClipboardList, LogOut, ArrowLeft, Home, Sliders } from "lucide-react";

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Admin | ToolHub</title>
    <ClientRouter />
  </head>
  <body class="bg-background text-foreground flex font-sans antialiased min-h-screen">
    
    {/* Sidebar Nav */}
    <aside class="w-64 bg-slate-900 text-slate-100 flex flex-col border-r border-slate-800 shrink-0">
      <div class="h-16 flex items-center px-6 border-b border-slate-800 gap-2">
        <Sliders class="h-5 w-5 text-primary" />
        <span class="font-heading font-bold text-lg tracking-tight text-white">ToolHub Admin</span>
      </div>

      <nav class="flex-1 px-4 py-6 space-y-1">
        <a
          href="/admin/"
          class={`flex items-center gap-3 px-3 py-2.5 rounded-md text-sm font-medium transition-colors ${
            currentPath === "/admin/" ? "bg-slate-800 text-white font-semibold" : "text-slate-400 hover:bg-slate-800 hover:text-white"
          }`}
        >
          <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
          Dashboard
        </a>
        <a
          href="/admin/tools/"
          class={`flex items-center gap-3 px-3 py-2.5 rounded-md text-sm font-medium transition-colors ${
            currentPath.startsWith("/admin/tools") ? "bg-slate-800 text-white font-semibold" : "text-slate-400 hover:bg-slate-800 hover:text-white"
          }`}
        >
          <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
          Calculators List
        </a>
        <a
          href="/admin/categories/"
          class={`flex items-center gap-3 px-3 py-2.5 rounded-md text-sm font-medium transition-colors ${
            currentPath.startsWith("/admin/categories") ? "bg-slate-800 text-white font-semibold" : "text-slate-400 hover:bg-slate-800 hover:text-white"
          }`}
        >
          <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none"><line x1="3" y1="21" x2="21" y2="21"></line><line x1="3" y1="10" x2="21" y2="10"></line><polygon points="12 2 2 10 22 10"></polygon></svg>
          Categories
        </a>
        <a
          href="/admin/contact/"
          class={`flex items-center gap-3 px-3 py-2.5 rounded-md text-sm font-medium transition-colors ${
            currentPath.startsWith("/admin/contact") ? "bg-slate-800 text-white font-semibold" : "text-slate-400 hover:bg-slate-800 hover:text-white"
          }`}
        >
          <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          Contact Inbox
        </a>
      </nav>

      {/* Footer / Exit */}
      <div class="p-4 border-t border-slate-800 flex flex-col gap-2">
        <a
          href="/"
          class="flex items-center gap-3 px-3 py-2 rounded-md text-sm font-medium text-slate-400 hover:bg-slate-800 hover:text-white transition-colors"
        >
          <Home class="h-4.5 w-4.5" />
          View Live Site
        </a>
        <button
          onclick="document.cookie = 'admin-session=; path=/; expires=Thu, 01 Jan 1970 00:00:01 GMT;'; window.location.href = '/admin/login/';"
          class="flex w-full items-center gap-3 px-3 py-2 rounded-md text-sm font-medium text-red-400 hover:bg-red-950/20 hover:text-red-300 transition-colors"
        >
          <LogOut class="h-4.5 w-4.5" />
          Log Out
        </button>
      </div>
    </aside>

    {/* Main Content Area */}
    <div class="flex-1 flex flex-col min-w-0">
      <header class="h-16 bg-card border-b border-border flex items-center justify-between px-8">
        <h2 class="text-lg font-heading font-semibold text-foreground">{title}</h2>
        <div class="text-sm text-muted">Admin Mode</div>
      </header>

      <main class="flex-1 p-8 overflow-y-auto">
        <slot />
      </main>
    </div>

  </body>
</html>
