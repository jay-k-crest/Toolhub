---
import "../styles/global.css";
import Header from "../components/layout/Header";
import Footer from "../components/layout/Footer.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  jsonLd?: Record<string, any> | Array<Record<string, any>>;
  robots?: string;
}

const {
  title,
  description = "Free online calculators and tools across finance, health, math, converters, real estate, and more. Clean, private, and instant results.",
  ogImage = "/og-default.png",
  ogType = "website",
  jsonLd,
  robots = "index, follow",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site || "https://www.toolhubs.me").href;

const jsonLdString = jsonLd ? JSON.stringify(jsonLd) : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#10B981" />
    <meta name="generator" content={Astro.generator} />

    {/* Primary Meta Tags */}
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={robots} />

    {/* Open Graph / Facebook */}
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, canonicalUrl).href} />

    {/* Twitter */}
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(ogImage, canonicalUrl).href} />

    {/* Google Analytics 4 */}
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-GA4-MEASUREMENT-ID-PLACEHOLDER"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-GA4-MEASUREMENT-ID-PLACEHOLDER');
    </script>

    {/* Theme Setup Script - runs inline to prevent flash */}
    <script is:inline>
      const getThemePreference = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };
      
      const isDark = getThemePreference() === 'dark';
      document.documentElement.classList[isDark ? 'add' : 'remove']('dark');
      
      if (typeof localStorage !== 'undefined') {
        // Watch theme changes
        const observer = new MutationObserver(() => {
          const isDark = document.documentElement.classList.contains('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
      }
    </script>

    {/* Structured Data (JSON-LD) */}
    {jsonLdString && <script type="application/ld+json" set:html={jsonLdString} />}

    <ClientRouter />

    {/* Analytics & Traffic Logging Script */}
    <script>
      const trackAnalytics = () => {
        if (typeof window === "undefined") return;

        // 1. Log Page View
        const pathname = window.location.pathname;
        fetch("/api/analytics/log-view", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ pathname }),
        }).catch(() => {});

        // 2. Expose a global logger for executions
        (window as any).logToolExecution = (toolSlug: string) => {
          fetch("/api/analytics/log-run", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ toolSlug }),
          }).catch(() => {});
        };
      };

      // Run on every page navigation (Astro ClientRouter compatibility)
      document.addEventListener("astro:page-load", trackAnalytics);

      // Track clicks on calculate buttons inside the calculator container
      document.addEventListener("click", (e) => {
        const container = document.getElementById("calculator-container");
        if (container && container.contains(e.target as Node)) {
          const target = e.target as HTMLElement;
          const button = target.closest("button");
          // If a button is clicked in the calculator, we count it as a tool run
          if (button) {
            const pathParts = window.location.pathname.split("/").filter(Boolean);
            if (pathParts.length === 2) {
              const toolSlug = pathParts[1];
              if ((window as any).logToolExecution) {
                (window as any).logToolExecution(toolSlug);
              }
            }
          }
        }
      });
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground flex flex-col font-sans antialiased transition-colors duration-150">
    <Header client:load toolsUrl="/tools-index.json" />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
