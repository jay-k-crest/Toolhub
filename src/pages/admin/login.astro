---
import "../../styles/global.css";
import { checkPassword, signSession } from "../../lib/auth";

export const prerender = false;

let error = "";

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const password = data.get("password")?.toString();

    if (password && checkPassword(password)) {
      const sessionValue = signSession();
      Astro.cookies.set("admin-session", sessionValue, {
        path: "/",
        httpOnly: true,
        secure: true,
        sameSite: "strict",
        maxAge: 60 * 60 * 24 * 7, // 7 days
      });
      return Astro.redirect("/admin/");
    } else {
      error = "Invalid password. Access denied.";
    }
  } catch (err) {
    console.error("Login submission error:", err);
    error = "Something went wrong. Please try again.";
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Admin Login — ToolHub</title>
  </head>
  <body class="bg-slate-900 text-slate-100 flex items-center justify-center min-h-screen font-sans">
    
    <div class="w-full max-w-sm p-6 bg-slate-800 border border-slate-700 rounded-xl shadow-lg space-y-6">
      <div class="text-center space-y-1.5">
        <h1 class="text-2xl font-heading font-extrabold tracking-tight text-white">ToolHub Admin</h1>
        <p class="text-xs text-slate-400">Enter system password to enter administrative dashboard</p>
      </div>

      <form method="POST" class="space-y-4">
        <div class="space-y-1.5">
          <label for="password-input" class="text-xs font-semibold uppercase tracking-wider text-slate-300">Admin Password</label>
          <input
            id="password-input"
            type="password"
            name="password"
            required
            placeholder="••••••••••••"
            class="w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-white placeholder:text-slate-600 focus:outline-none focus:ring-2 focus:ring-primary"
          />
        </div>

        {error && (
          <div class="p-3 rounded-md bg-red-500/10 border border-red-500/20 text-red-400 text-xs font-semibold text-center">
            {error}
          </div>
        )}

        <button
          type="submit"
          class="w-full inline-flex items-center justify-center h-10 px-4 py-2 text-sm font-semibold rounded-md bg-primary text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Verify Password
        </button>
      </form>
      
      <div class="text-center">
        <a href="/" class="text-xs text-slate-400 hover:text-white transition-colors underline">Return to Live Homepage</a>
      </div>
    </div>

  </body>
</html>
