---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getToolBySlug, clearCache } from "../../../lib/data";
import { db } from "../../../lib/db";
import { tools } from "../../../lib/schema";
import { eq } from "drizzle-orm";

export const prerender = false;

const { id } = Astro.params;
if (!id) {
  return Astro.redirect("/admin/tools/");
}

const tool = await getToolBySlug(id);
if (!tool) {
  return Astro.redirect("/admin/tools/");
}

let success = "";
let error = "";

if (Astro.request.method === "POST") {
  if (!db) {
    error = "Database is not connected. Edits cannot be saved.";
  } else {
    try {
      const data = await Astro.request.formData();
      const name = data.get("name")?.toString() || "";
      const metaTitle = data.get("metaTitle")?.toString() || "";
      const metaDescription = data.get("metaDescription")?.toString() || "";
      const shortDesc = data.get("shortDesc")?.toString() || "";
      const introContent = data.get("introContent")?.toString() || "";
      const displayOrder = Number(data.get("displayOrder") || "0");
      const isActive = data.get("isActive") === "on";

      await db.update(tools)
        .set({
          name,
          metaTitle,
          metaDescription,
          shortDesc,
          introContent,
          displayOrder,
          isActive,
          updatedAt: new Date(),
        })
        .where(eq(tools.slug, tool.slug));

      clearCache();

      success = "Configuration updated successfully!";
      
      // Update local tool reference for display
      tool.name = name;
      tool.metaTitle = metaTitle;
      tool.metaDescription = metaDescription;
      tool.shortDesc = shortDesc;
      tool.introContent = introContent;
      tool.displayOrder = displayOrder;
      tool.isActive = isActive;

    } catch (e) {
      console.error("Failed to update tool config:", e);
      error = "An error occurred while saving.";
    }
  }
}
---

<AdminLayout title={`Edit Config: ${tool.name}`}>
  <div class="max-w-3xl space-y-6">
    <div class="flex items-center gap-4">
      <a href="/admin/tools/" class="inline-flex items-center justify-center h-8 px-3 text-xs font-bold rounded-md border border-border bg-card hover:bg-secondary text-foreground transition-colors">
        &larr; Back to List
      </a>
      <span class="text-xs text-muted font-mono">ID: {tool.slug}</span>
    </div>

    {success && (
      <div class="p-4 rounded-lg bg-emerald-500/10 border border-emerald-500/20 text-emerald-500 text-sm font-semibold">
        {success}
      </div>
    )}

    {error && (
      <div class="p-4 rounded-lg bg-red-500/10 border border-red-500/20 text-red-500 text-sm font-semibold">
        {error}
      </div>
    )}

    <form method="POST" class="space-y-6 bg-card border border-border rounded-xl p-6 sm:p-8 shadow-sm">
      
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        
        {/* Tool Name */}
        <div class="space-y-1.5 col-span-2">
          <label for="name-input" class="text-sm font-semibold text-foreground">Calculator Name</label>
          <input
            id="name-input"
            type="text"
            name="name"
            required
            value={tool.name}
            class="w-full rounded-md border border-input bg-card px-3 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
          />
        </div>

        {/* Short Description */}
        <div class="space-y-1.5 col-span-2">
          <label for="short-desc-input" class="text-sm font-semibold text-foreground">Short Description (for cards)</label>
          <textarea
            id="short-desc-input"
            name="shortDesc"
            rows={2}
            class="w-full rounded-md border border-input bg-card px-3 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
          >{tool.shortDesc}</textarea>
        </div>

        {/* Meta Title */}
        <div class="space-y-1.5">
          <label for="meta-title-input" class="text-sm font-semibold text-foreground">SEO Meta Title</label>
          <input
            id="meta-title-input"
            type="text"
            name="metaTitle"
            value={tool.metaTitle}
            class="w-full rounded-md border border-input bg-card px-3 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
          />
        </div>

        {/* Display Order */}
        <div class="space-y-1.5">
          <label for="order-input" class="text-sm font-semibold text-foreground">Display Order (Sorting)</label>
          <input
            id="order-input"
            type="number"
            name="displayOrder"
            value={tool.displayOrder}
            class="w-full rounded-md border border-input bg-card px-3 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
          />
        </div>

        {/* Meta Description */}
        <div class="space-y-1.5 col-span-2">
          <label for="meta-desc-input" class="text-sm font-semibold text-foreground">SEO Meta Description</label>
          <textarea
            id="meta-desc-input"
            name="metaDescription"
            rows={3}
            class="w-full rounded-md border border-input bg-card px-3 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
          >{tool.metaDescription}</textarea>
        </div>

        {/* Intro content */}
        <div class="space-y-1.5 col-span-2">
          <label for="intro-content-input" class="text-sm font-semibold text-foreground">Intro Content (Markdown / HTML)</label>
          <textarea
            id="intro-content-input"
            name="introContent"
            rows={6}
            class="w-full rounded-md border border-input bg-card px-3 py-2 text-sm text-foreground font-mono text-xs focus:outline-none focus:ring-2 focus:ring-primary"
          >{tool.introContent}</textarea>
        </div>

        {/* Active Toggle */}
        <div class="col-span-2 flex items-center gap-3">
          <input
            id="active-toggle"
            type="checkbox"
            name="isActive"
            checked={tool.isActive}
            class="h-4 w-4 rounded border-gray-300 text-primary focus:ring-primary"
          />
          <label for="active-toggle" class="text-sm font-semibold text-foreground select-none">
            Publish status (Make this calculator visible to users)
          </label>
        </div>

      </div>

      <div class="pt-4 border-t border-border flex justify-end">
        <button
          type="submit"
          class="inline-flex items-center justify-center h-10 px-6 font-bold rounded-md bg-primary text-primary-foreground hover:bg-primary/90 transition-colors"
        >
          Save Configurations
        </button>
      </div>

    </form>
  </div>
</AdminLayout>
