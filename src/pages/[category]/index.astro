---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AdSlot from "../../components/layout/AdSlot.astro";
import { getCategories, getToolsByCategory } from "../../lib/data";
import { ChevronRight, Calculator } from "lucide-react";

export async function getStaticPaths() {
  const categories = await getCategories();
  return categories.map(cat => ({
    params: { category: cat.slug },
    props: { category: cat }
  }));
}

const { category } = Astro.props;
const tools = await getToolsByCategory(category.slug);
const isSparseCategory = tools.length <= 4;

const siteUrl = Astro.site ? Astro.site.origin : "https://www.toolhubs.me";
const categoryUrl = `${siteUrl}/${category.slug}/`;

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": category.name,
      "item": categoryUrl
    }
  ]
};

const displayTitle = `${category.name} Calculators & Tools — Free Online | ToolHub`;
const displayDescription = `Free online ${category.name} calculators and web tools. ${category.description}`;
---

<BaseLayout title={displayTitle} description={displayDescription} jsonLd={breadcrumbLd}>
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    
    {/* Breadcrumbs */}
    <nav class="flex items-center space-x-1 text-xs text-muted mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-primary transition-colors">Home</a>
      <ChevronRight class="h-3 w-3" />
      <span class="text-foreground font-medium" aria-current="page">{category.name}</span>
    </nav>

    {/* Header */}
    <div class="mb-10">
      <h1 class="text-3xl font-heading font-extrabold tracking-tight sm:text-4xl md:text-5xl mb-4 text-foreground">
        {category.name} Calculators
      </h1>
      <p class="text-base sm:text-lg text-muted max-w-3xl leading-relaxed">
        We offer a suite of free, high-performance web calculators in the {category.name} domain.
        All tools run entirely in the client's browser, protecting user privacy and ensuring instant feedback.
        Browse the available calculators below, and pick the one that matches your target analysis.
      </p>
    </div>

    {/* Layout Structure adapts for small categories */}
    <div class={isSparseCategory ? "space-y-8" : "grid grid-cols-1 lg:grid-cols-12 gap-8 items-start"}>
      
      {/* Main Tools Grid */}
      <div class={isSparseCategory ? "space-y-8" : "lg:col-span-8 space-y-8"}>
        {tools.length === 0 ? (
          <div class="rounded-lg border border-dashed border-border p-12 text-center text-muted">
            No calculators are currently active in this category. Check back soon!
          </div>
        ) : (
          <div class="space-y-4">
            <h2 class="text-xl font-heading font-bold text-foreground">Available {category.name} Calculators</h2>
            <div class={isSparseCategory ? "grid grid-cols-1 sm:grid-cols-2 gap-6 justify-items-stretch mx-auto max-w-4xl" : "grid grid-cols-1 sm:grid-cols-2 gap-6"}>
              {tools.map((tool, idx) => (
                <>
                  <a
                    href={`/${category.slug}/${tool.slug}/`}
                    class={`group p-5 rounded-lg border border-border bg-card shadow-sm hover:border-primary hover:shadow-md transition-all duration-150 flex flex-col justify-between ${isSparseCategory ? "w-full" : ""}`}
                  >
                    <div>
                      <h3 class="font-heading font-bold text-foreground group-hover:text-primary transition-colors text-base flex items-center gap-2">
                        <Calculator class="h-4.5 w-4.5 text-muted group-hover:text-primary transition-colors" />
                        {tool.name}
                      </h3>
                      <p class="text-xs sm:text-sm text-muted mt-2 leading-relaxed">
                        {tool.shortDesc}
                      </p>
                    </div>
                    
                    <span class="text-xs text-primary font-bold mt-4 inline-flex items-center gap-0.5">
                      Open Calculator
                      <ChevronRight class="h-3 w-3 group-hover:translate-x-0.5 transition-transform" />
                    </span>
                  </a>

                  {/* Ad slot in-feed after every 6 tools */}
                  {(idx + 1) % 6 === 0 && (
                    <div class="col-span-1 sm:col-span-2">
                      <AdSlot placement="in-feed" />
                    </div>
                  )}
                </>
              ))}
            </div>
          </div>
        )}

        {isSparseCategory && tools.length > 0 && (
          <div class="max-w-4xl mx-auto">
            <AdSlot placement="mid-content" />
          </div>
        )}
      </div>

      {!isSparseCategory && (
        /* Sidebar Ad */
        <div class="lg:col-span-4 lg:sticky lg:top-24">
          <AdSlot placement="sidebar-sticky" className="hidden lg:block" />
        </div>
      )}

    </div>

  </div>
</BaseLayout>
